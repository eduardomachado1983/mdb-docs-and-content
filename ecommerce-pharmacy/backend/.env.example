# Environment
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Frontend
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce_pharmacy
DB_LOGGING=false
DB_SYNCHRONIZE=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRY=7d

# AWS S3 / MinIO
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=ecommerce-pharmacy-files
S3_FOLDER=documents

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (SendGrid or similar)
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@pharmacy.local
EMAIL_FROM_NAME=Pharmacy Platform

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# OCR (Tesseract)
TESSERACT_LANGUAGE=por+eng
TESSERACT_CONFIG_PATH=/usr/share/tesseract-ocr/tessdata

# Admin Settings
ADMIN_EMAIL=admin@pharmacy.local
ADMIN_PASSWORD=change-me-in-production

# Document Validation
DOC_MAX_FILE_SIZE=5242880  # 5MB in bytes
DOC_ALLOWED_TYPES=application/pdf,image/jpeg,image/png
DOC_EXPIRY_DAYS=90
DOC_EXPIRY_WARNING_DAYS=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your-super-secret-session-key

# Monitoring (Optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/000000
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=

# Development
DEBUG=pharmacy:*
MOCK_PAYMENTS=false
