# Environment
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3001

# Payment
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# Sentry (Optional)
NEXT_PUBLIC_SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Feature Flags
NEXT_PUBLIC_FEATURE_MARKETPLACE=false
NEXT_PUBLIC_FEATURE_SUBSCRIPTION=false
NEXT_PUBLIC_FEATURE_MOBILE_APP=false

# UI Theme
NEXT_PUBLIC_THEME_COLOR=#4A90E2

# Document Upload
NEXT_PUBLIC_MAX_FILE_SIZE=5242880  # 5MB in bytes
NEXT_PUBLIC_ALLOWED_FILE_TYPES=pdf,jpeg,png,jpg

# Pagination
NEXT_PUBLIC_ITEMS_PER_PAGE=20

# API Timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# Debug
DEBUG=pharmacy:*
