# ══════════════════════════════════════
# BioSativa — Env Variables
# Copie para .env.local e preencha
# ══════════════════════════════════════

# Supabase — app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mercado Pago — mercadopago.com.br → Desenvolvedor
# NUNCA exponha o access token no frontend
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx
MERCADOPAGO_WEBHOOK_SECRET=xxxx
# Public key — usada no cliente para tokenizar cartão via MercadoPago.js
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxx

# Site
NEXT_PUBLIC_SITE_URL=https://biosativa.vercel.app

# Valor da consulta em centavos
CONSULTATION_AMOUNT=200

# WhatsApp Cloud API (Meta) — developers.facebook.com/apps → WhatsApp → API Setup
# Sem essas variáveis, o envio roda em modo simulado (não envia de fato).
WHATSAPP_ACCESS_TOKEN=xxxx
WHATSAPP_PHONE_NUMBER_ID=xxxx
# Token que você mesmo escolhe e informa ao cadastrar o webhook na Meta
WHATSAPP_VERIFY_TOKEN=xxxx
# App secret — usado para validar a assinatura das requisições do webhook
WHATSAPP_APP_SECRET=xxxx
